---
interface Props {
    titulo: string;
    descricao: string;
    img_url: string;
    img_height?: string;
}

const { titulo, descricao, img_url, img_height = "auto" } = Astro.props;
---

<div
    class="bg-gray-800 rounded-2xl overflow-hidden shadow-md border border-gray-600 transition-transform hover:scale-[1.02]"
>
    <div class="p-4">
        <h3 class="text-xl font-bold text-gray-300">{titulo}</h3>
        <p class="text-gray-400 mt-2 text-sm leading-relaxed">
            {descricao}
        </p>

        <!-- Imagem responsiva mantendo proporção -->
        <img
            src={img_url}
            alt={titulo}
            style={`width: 100%; height: ${img_height};`}
            class="object-contain"
        />
    </div>
</div>
