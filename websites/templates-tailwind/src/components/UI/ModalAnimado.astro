---
interface Props {
    id: string;
}
const { id } = Astro.props;

const gif_pikachu =
    "https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExN3FnZXAxOWFlemUyNHk2bXkzd3h3aXE2eDE2cnR6dnJyMGRxc3h5aiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/vnGlErQHuF9BK/giphy.gif";
---

<dialog id={id} class="fixed inset-0 z-[100] outline-none">
    <div
        class="bg-[#1e1e1e] border-2 border-[#ff9800] p-8 rounded-3xl max-w-[340px] w-[90vw] text-center shadow-[0_0_50px_rgba(255,152,0,0.4)] relative"
    >
        <div class="mb-4 text-6xl animate-bounce">🎉</div>
        <h2
            class="text-2xl font-bold text-white mb-2 uppercase tracking-tighter"
        >
            Dia Concluído!
        </h2>
        <p class="text-gray-400 mb-6 text-sm">
            Excelente! Você completou todas as etapas neste dia de viagem!
        </p>

        <img
            src="https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExN3FnZXAxOWFlemUyNHk2bXkzd3h3aXE2eDE2cnR6dnJyMGRxc3h5aiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/vnGlErQHuF9BK/giphy.gif"
            alt="Sucesso"
            class="rounded-xl mb-6 w-full h-40 object-cover border border-gray-800"
        />

        <button
            data-close-modal
            class="w-full bg-[#ff9800] hover:bg-orange-600 text-black font-black py-4 rounded-xl transition-all active:scale-95 uppercase text-sm tracking-widest"
        >
            Fechar
        </button>
    </div>
</dialog>

<canvas id="confetti-canvas" class="fixed inset-0 pointer-events-none z-[60]"
></canvas>

<style>
    /* 1. Reset do Dialog */
    dialog {
        padding: 0;
        border: none;
        background: transparent;
        max-width: none;
        max-height: none;
        overflow: visible;
        /* Garante que ocupe a tela toda para o backdrop funcionar */
        width: 100vw;
        height: 100vh;
    }

    /* 2. Backdrop (Fundo escuro) */
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(4px);
        animation: fadeIn 0.4s ease forwards;
    }

    /* 3. Animação de Entrada e Centralização */
    dialog[open] {
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.2s ease forwards;
    }

    dialog[open] > div {
        animation: popIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes popIn {
        from {
            opacity: 0;
            transform: scale(0.8);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>
