<div
    id="travel-toast"
    class="fixed top-4 right-4 z-50 opacity-0 translate-y-[-10px] pointer-events-none transition-all duration-300"
>
    <div
        class="px-4 py-3 rounded-lg border shadow-lg backdrop-blur-sm flex items-center gap-3 bg-green-900/90 border-green-500 text-green-100"
    >
        <span class="text-sm font-medium" data-toast-text> Mensagem </span>
    </div>
</div>

<script is:inline>
    const toast = document.getElementById("travel-toast");
    const toastText = toast?.querySelector("[data-toast-text]");

    function showToast(message) {
        if (!toast || !toastText) return;

        toastText.textContent = message;
        toast.classList.remove("opacity-0", "translate-y-[-10px]");
        toast.classList.add(
            "opacity-100",
            "translate-y-0",
            "pointer-events-auto",
        );

        window.clearTimeout(window.__travelToastTimer);
        window.__travelToastTimer = window.setTimeout(() => {
            toast.classList.add("opacity-0", "translate-y-[-10px]");
            toast.classList.remove(
                "opacity-100",
                "translate-y-0",
                "pointer-events-auto",
            );
        }, 4000);
    }

    window.addEventListener("travel:toast", (event) => {
        showToast(event.detail?.message || "Pronto!");
    });
</script>
