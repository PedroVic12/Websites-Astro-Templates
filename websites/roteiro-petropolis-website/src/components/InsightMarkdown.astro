---
interface Props {
    content: string;
    title?: string;
    emoji?: string;
}

const { content, title = "Insight Avançado", emoji = "🧠" } = Astro.props;

// Função para converter markdown básico em HTML
function markdownToHtml(md: string): string {
    let html = md
        // Títulos
        .replace(
            /^### (.*?)$/gm,
            '<h4 class="text-lg font-bold text-[#ff9800] mt-6 mb-3">$1</h4>',
        )
        .replace(
            /^## (.*?)$/gm,
            '<h3 class="text-xl font-bold text-white mt-8 mb-4">$1</h3>',
        )
        .replace(
            /^# (.*?)$/gm,
            '<h2 class="text-2xl font-bold text-white mt-10 mb-4">$1</h2>',
        )
        // Listas com checkboxes
        .replace(
            /^- \[ \] (.*?)$/gm,
            '<div class="flex items-start gap-3 mb-2"><input type="checkbox" class="mt-1" /><span class="text-lg text-gray-300">$1</span></div>',
        )
        .replace(/^- (.*?)$/gm, '<li class="text-gray-400 ml-16">$1</li>')
        // Negrito
        .replace(
            /\*\*(.*?)\*\*/g,
            '<strong class="font-bold text-white">$1</strong>',
        )
        // Itálico
        .replace(/\*(.*?)\*/g, '<em class="italic">$1</em>')
        // Quebras de linha
        .replace(/\n\n/g, "</p><p>")
        .replace(/\n/g, "<br />");

    // Envolver parágrafos
    if (!html.includes("<p>")) {
        html = `<p>${html}</p>`;
    }

    return html;
}

const htmlContent = markdownToHtml(content);
---

<section
    class="mt-20 mx-4 md:mx-auto max-w-4xl bg-gradient-to-br from-gray-900 to-black border border-gray-800 rounded-3xl p-8 relative overflow-hidden shadow-2xl shadow-black/40"
>
    <div
        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#ff9800] to-[#00bcd4]"
    >
    </div>

    <span class="text-4xl mb-4 block">{emoji}</span>
    <h3 class="text-2xl font-bold text-white mb-6">{title}</h3>

    <div
        class="text-gray-300 text-left leading-relaxed space-y-4 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-white [&_h2]:mt-6 [&_h2]:mb-3 [&_h3]:text-lg [&_h3]:font-bold [&_h3]:text-[#ff9800] [&_h3]:mt-4 [&_h3]:mb-2 [&_h4]:font-bold [&_h4]:text-[#ff9800] [&_ul]:list-disc [&_ul]:ml-6 [&_ol]:list-decimal [&_ol]:ml-6 [&_li]:mb-2 [&_strong]:text-white [&_strong]:font-bold"
        set:html={htmlContent}
    />

    <button
        class="mt-8 border border-orange-500/50 text-orange-500 hover:bg-orange-500 hover:text-black px-6 py-2 rounded-full font-medium transition-all"
        type="button"
        onclick="window.open('https://onsbr-my.sharepoint.com/:x:/g/personal/viviane_alves_ons_org_br/IQD7uaPKmfVURIkzXUOXEMb3Ad1uN-Ngjd5O5ZuIatiBhOk?wdExp=TEAMS-TREATMENT&web=1', '_blank')"
