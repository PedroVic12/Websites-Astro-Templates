---
export interface Props {
    titulo: string;
    variant?: "primary" | "secondary" | "danger";
    onClick?: string;
}
const { titulo, variant = "primary", onClick } = Astro.props;

const variants: Record<string, string> = {
    primary: "bg-blue-600 hover:bg-blue-700 border-blue-700",
    secondary: "bg-gray-800 hover:bg-gray-900 border-gray-700",
    danger: "bg-red-600 hover:bg-red-700 border-red-700",
};

const classes = `w-full ${variants[variant]} text-white py-3 rounded-xl font-semibold shadow-lg active:opacity-90 border transition-colors`;
---

<button type="button" class={classes} data-trigger-global data-method={onClick}>
    {titulo}
</button>

<script>
    // Este script roda uma vez no cliente e ativa TODOS os botões deste tipo
    const buttons = document.querySelectorAll("[data-trigger-global]");

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const methodName = btn.getAttribute("data-method");
            if (
                methodName &&
                typeof (window as any)[methodName] === "function"
            ) {
                (window as any)[methodName]();
            }
        });
    });
</script>
