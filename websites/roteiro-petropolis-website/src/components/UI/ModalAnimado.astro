---
interface Props {
    id: string;
}
const { id } = Astro.props;
---

<dialog
    id={id}
    class="fixed inset-0 z-50 bg-transparent backdrop:bg-black/80 open:flex flex-col items-center justify-center p-4"
>
    <div
        class="bg-[#1e1e1e] border-2 border-[#ff9800] p-8 rounded-3xl max-w-sm w-full text-center shadow-[0_0_50px_rgba(255,152,0,0.3)]"
    >
        <div class="mb-4 text-6xl">🎉</div>
        <h2 class="text-2xl font-bold text-white mb-2">Dia Concluído!</h2>
        <p class="text-gray-400 mb-6">
            Você completou todas as atividades de hoje. Pronto para a próxima?
        </p>

        <!-- GIF Opcional -->
        <img
            src="https://media0.giphy.com/media/v1.Y2lkPTc5MGI3NjExb2hkbWVmaXNydDcwdnhqeWlteXhsbTVubDMyYmV1bm1qdnZseHZsZCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/EktbegF3J8QIo/giphy.gif"
            alt="Sucesso"
            class="rounded-lg mb-6 w-full h-40 object-cover border border-gray-800"
        />

        <button
            data-close-modal
            class="w-full bg-[#ff9800] hover:bg-orange-600 text-black font-bold py-3 rounded-xl transition-all active:scale-95"
        >
            Concluir
        </button>
    </div>
</dialog>

<style>
    dialog::backdrop {
        animation: fadeIn 0.3s ease forwards;
    }
    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
</style>
