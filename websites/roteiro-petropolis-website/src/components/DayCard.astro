---
import ButtonTailwind from "./UI/ButtonTailwind.astro";

const { day } = Astro.props;
---

<div class="relative pl-8 md:pl-12">
    <div
        class="absolute -left-[17px] top-0 w-8 h-8 bg-[#ff9800] rounded-full flex items-center justify-center font-bold text-black border-4 border-black shadow-md"
    >
        {day.day}
    </div>

    <h3 class="text-xl font-bold text-white">DIA {day.day} — {day.title}</h3>
    <p class="text-orange-400 text-sm font-medium mb-6 mt-1">
        👉 Foco: {day.focus}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
            day.events.map((ev: any) => (
                <div class="bg-[#1e1e1e]/70 border border-gray-800 p-4 rounded-xl flex items-start gap-3 shadow-lg">
                    <span class="text-2xl">{ev.icon}</span>
                    <div>
                        <h4 class="text-[#ff9800] font-bold text-sm mb-1">
                            {ev.time}
                        </h4>
                        <p class="text-gray-300 text-sm leading-relaxed">
                            {ev.desc}
                        </p>
                    </div>
                </div>
            ))
        }
    </div>

    {/* 👇 Condicional: Só renderiza se for o Dia 1 */}
    {
        day.day === 1 && (
            <div class=" w-full p-4 bg-gradient-to-t to-transparent md:hidden z-40">
                <ButtonTailwind
                    titulo="Ver mapa do Hotel"
                    variant="primary"
                    onClick="abrirNoMaps"
                />
            </div>
        )
    }
</div>
