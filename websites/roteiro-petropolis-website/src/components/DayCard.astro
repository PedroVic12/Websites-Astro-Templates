---
import ButtonTailwind from "./UI/ButtonTailwind.astro";

const { day } = Astro.props;
// Geramos um ID único para este dia para salvar o progresso individualmente
const dayId = `day-${day.day}`;
---

<div class="relative pl-8 md:pl-12 day-container" data-day-id={dayId}>
    <div
        class="absolute -left-[17px] top-0 w-8 h-8 bg-[#ff9800] rounded-full flex items-center justify-center font-bold text-black border-4 border-black shadow-md"
    >
        {day.day}
    </div>

    <div class="flex justify-between items-center mb-2">
        <h3 class="text-xl font-bold text-white">DIA {day.day} — {day.title}</h3>
        <!-- Barra de Progresso do Dia -->
        <div class="hidden sm:block w-32 bg-gray-800 h-2 rounded-full overflow-hidden border border-gray-700">
            <div class="progress-bar bg-[#ff9800] h-full transition-all duration-500 w-0"></div>
        </div>
    </div>
    
    <p class="text-orange-400 text-sm font-medium mb-6 mt-1">
        👉 Foco: {day.focus}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
            day.events.map((ev: any, index: number) => (
                <label class="cursor-pointer group">
                    <div class="event-card bg-[#1e1e1e]/70 border border-gray-800 p-4 rounded-xl flex items-start gap-4 shadow-lg transition-all hover:border-orange-500/50 has-[:checked]:border-[#ff9800] has-[:checked]:bg-[#ff9800]/5">
                        
                        <!-- Checkbox customizado -->
                        <div class="relative flex items-center mt-1">
                            <input 
                                type="checkbox" 
                                class="event-checkbox peer appearance-none w-5 h-5 border-2 border-gray-600 rounded-md checked:bg-[#ff9800] checked:border-[#ff9800] transition-all"
                                data-index={index}
                            />
                            <svg class="absolute w-3.5 h-3.5 text-black font-bold hidden peer-checked:block left-[3px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"></path></svg>
                        </div>

                        <div class="peer-checked:opacity-50 transition-opacity">
                            <h4 class="text-[#ff9800] font-bold text-sm mb-1 group-has-[:checked]:line-through">
                                {ev.time}
                            </h4>
                            <p class="text-gray-300 text-sm leading-relaxed group-has-[:checked]:text-gray-500">
                                {ev.desc}
                            </p>
                        </div>
                    </div>
                </label>
            ))
        }
    </div>

    {
        day.day === 1 && (
            <div class="w-full p-4 mt-4 bg-gradient-to-t to-transparent md:hidden z-40">
                <ButtonTailwind
                    titulo="Ver mapa do Hotel"
                    variant="primary"
                    onClick="abrirNoMaps"
                />
            </div>
        )
    }
</div>

<script>
    function updateProgress(container: HTMLElement) {
        const checkboxes = container.querySelectorAll('.event-checkbox') as NodeListOf<HTMLInputElement>;
        const progressBar = container.querySelector('.progress-bar') as HTMLElement;
        const dayId = container.getAttribute('data-day-id');
        
        const total = checkboxes.length;
        const checked = Array.from(checkboxes).filter(i => i.checked).length;
        const percentage = total > 0 ? (checked / total) * 100 : 0;

        if (progressBar) progressBar.style.width = `${percentage}%`;

        // Salvar no LocalStorage
        const state = Array.from(checkboxes).map(i => i.checked);
        localStorage.setItem(`progresso-${dayId}`, JSON.stringify(state));
    }

    // Inicialização
    document.querySelectorAll('.day-container').forEach((container: any) => {
        const dayId = container.getAttribute('data-day-id');
        const checkboxes = container.querySelectorAll('.event-checkbox');
        const saved = JSON.parse(localStorage.getItem(`progresso-${dayId}`) || '[]');

        checkboxes.forEach((cb: HTMLInputElement, index: number) => {
            // Restaurar estado salvo
            if (saved[index]) cb.checked = true;

            // Escutar mudanças
            cb.addEventListener('change', () => updateProgress(container));
        });

        // Atualiza barra inicialmente
        updateProgress(container);
    });
</script>
