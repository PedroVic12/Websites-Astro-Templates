---
const { logistics, base } = Astro.props;
---

<div
    class="grid grid-cols-1 md:grid-cols-3 gap-6 px-4 md:px-10 -mt-12 relative z-20"
>
    <div
        class="bg-[#1e1e1e] border border-gray-800 p-6 rounded-2xl shadow-xl shadow-black/50 hover:border-orange-500/50 transition-colors"
    >
        <div class="flex items-center gap-3 mb-4 text-[#ff9800]">
            <span class="text-3xl">🚙</span>
            <h3 class="text-xl font-bold text-white">Deslocamento</h3>
        </div>
        <p class="text-gray-400 text-sm mb-2">
            <strong class="text-gray-200">Rota:</strong>
            {logistics.route.join(" → ")}
        </p>
        <p class="text-gray-400 text-sm">
            <strong class="text-gray-200">Tempo:</strong>
            {logistics.time}
        </p>
    </div>

    <div
        class="bg-[#1e1e1e] border border-gray-800 p-6 rounded-2xl shadow-xl shadow-black/50 hover:border-cyan-500/50 transition-colors"
    >
        <div class="flex items-center gap-3 mb-4 text-[#00bcd4]">
            <span class="text-3xl">🏨</span>
            <h3 class="text-xl font-bold text-white">Hospedagem</h3>
        </div>
        <p class="text-gray-400 text-sm">
            <strong class="text-[#00bcd4] block mb-1">{base}</strong>
            Estratégia perfeita: resolva a maior parte a pé e use o carro apenas para
            a serra.
        </p>
    </div>

    <div
        class="bg-[#1e1e1e] border border-gray-800 p-6 rounded-2xl shadow-xl shadow-black/50 hover:border-yellow-500/50 transition-colors"
    >
        <div class="flex items-center gap-3 mb-4 text-yellow-500">
            <span class="text-3xl">⚠️</span>
            <h3 class="text-xl font-bold text-white">Dicas Cruciais</h3>
        </div>
        <div class="flex flex-col gap-2">
            {
                logistics.tips.map((tip: any) => (
                    <span class="text-xs bg-yellow-900/20 text-yellow-500 border border-yellow-700/30 px-3 py-1.5 rounded-md">
                        {tip}
                    </span>
                ))
            }
        </div>
    </div>
</div>
